<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Geometry Dash Mini</title>
<style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: linear-gradient(135deg, #0f2027, #2c5364);
        color: white;
        text-align: center;
    }

    canvas {
        display: block;
        margin: 20px auto;
        background: #111;
        border-radius: 10px;
        box-shadow: 0 0 20px rgba(0,0,0,0.5);
    }

    .screen {
        position: absolute;
        width: 100%;
        top: 30%;
        left: 0;
    }

    button {
        padding: 10px 20px;
        border: none;
        border-radius: 6px;
        background: #00c9a7;
        color: white;
        font-size: 16px;
        cursor: pointer;
    }

    button:hover {
        background: #00a38a;
    }

    #score {
        font-size: 20px;
    }
</style>
</head>
<body>

<div id="startScreen" class="screen">
    <h1>Geometry Dash Mini</h1>
    <p>Press <b>SPACEBAR</b> to jump</p>
    <p>Avoid obstacles and survive as long as possible!</p>
    <button onclick="startGame()">Start Game</button>
</div>

<div id="gameOverScreen" class="screen" style="display:none;">
    <h1>Game Over</h1>
    <p id="finalScore"></p>
    <button onclick="restartGame()">Restart</button>
</div>

<div id="score" style="display:none;">Score: 0</div>

<canvas id="gameCanvas" width="800" height="300"></canvas>

<script>
const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");

let player, obstacles, score, frame, running;

// SPACEBAR only interaction
document.addEventListener("keydown", (e) => {
    if (e.code === "Space") {
        if (running && player.grounded) {
            player.dy = -12;
            player.grounded = false;
        }
    }
});

function startGame() {
    document.getElementById("startScreen").style.display = "none";
    document.getElementById("score").style.display = "block";
    init();
}

function restartGame() {
    document.getElementById("gameOverScreen").style.display = "none";
    init();
}

function init() {
    player = {
        x: 100,
        y: 200,
        size: 30,
        dy: 0,
        gravity: 0.8,
        grounded: true
    };

    obstacles = [];
    score = 0;
    frame = 0;
    running = true;

    gameLoop();
}

function gameOver() {
    running = false;
    document.getElementById("finalScore").innerText = "Final Score: " + score;
    document.getElementById("gameOverScreen").style.display = "block";
}

function update() {
    if (!running) return;

    frame++;
    score++;
    document.getElementById("score").innerText = "Score: " + score;

    // Player physics
    player.dy += player.gravity;
    player.y += player.dy;

    if (player.y >= 200) {
        player.y = 200;
        player.dy = 0;
        player.grounded = true;
    }

    // Spawn obstacles
    if (frame % 90 === 0) {
        obstacles.push({
            x: canvas.width,
            y: 210,
            width: 20,
            height: 40
        });
    }

    // Move obstacles
    obstacles.forEach((obs, i) => {
        obs.x -= 6;

        // Collision
        if (
            player.x < obs.x + obs.width &&
            player.x + player.size > obs.x &&
            player.y < obs.y + obs.height &&
            player.y + player.size > obs.y
        ) {
            gameOver();
        }

        // Remove off screen
        if (obs.x + obs.width < 0) {
            obstacles.splice(i, 1);
        }
    });
}

function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // Ground
    ctx.fillStyle = "#00c9a7";
    ctx.fillRect(0, 230, canvas.width, 5);

    // Player
    ctx.fillStyle = "#00c9a7";
    ctx.fillRect(player.x, player.y, player.size, player.size);

    // Obstacles
    ctx.fillStyle = "#ff4d6d";
    obstacles.forEach(obs => {
        ctx.fillRect(obs.x, obs.y, obs.width, obs.height);
    });
}

function gameLoop() {
    update();
    draw();
    if (running) requestAnimationFrame(gameLoop);
}
</script>

</body>
</html>
