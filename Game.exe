
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Mini Geometry Dash</title>
<style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
        color: white;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
    }

    #gameContainer {
        text-align: center;
    }

    canvas {
        background: #111;
        border: 3px solid #00e5ff;
        border-radius: 10px;
        display: none;
    }

    .screen {
        max-width: 400px;
    }

    button {
        padding: 10px 20px;
        font-size: 16px;
        border: none;
        border-radius: 5px;
        background: #00e5ff;
        color: black;
        cursor: pointer;
        margin-top: 15px;
    }

    button:hover {
        background: #00bcd4;
    }

    #score {
        margin-top: 10px;
        font-size: 18px;
    }
</style>
</head>
<body>

<div id="gameContainer">

    <!-- START SCREEN -->
    <div id="startScreen" class="screen">
        <h1>Geometry Dash Mini</h1>
        <p>
            Press <b>SPACEBAR</b> to jump.<br>
            Avoid the spikes.<br>
            Survive as long as possible!
        </p>
        <button onclick="startGame()">Start Game</button>
    </div>

    <!-- GAME -->
    <canvas id="gameCanvas" width="500" height="200"></canvas>
    <div id="score"></div>

    <!-- GAME OVER -->
    <div id="gameOverScreen" class="screen" style="display:none;">
        <h2>Game Over</h2>
        <p id="finalScore"></p>
        <button onclick="restartGame()">Restart</button>
    </div>

</div>

<script>
const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");

let player, gravity, obstacles, gameSpeed, score, isGameRunning;

// PLAYER
function initGame() {
    player = {
        x: 50,
        y: 150,
        width: 20,
        height: 20,
        dy: 0,
        jumping: false
    };

    gravity = 0.6;
    obstacles = [];
    gameSpeed = 4;
    score = 0;
    isGameRunning = true;
}

// DRAW PLAYER
function drawPlayer() {
    ctx.fillStyle = "#00e5ff";
    ctx.fillRect(player.x, player.y, player.width, player.height);
}

// DRAW OBSTACLES
function drawObstacles() {
    ctx.fillStyle = "#ff1744";
    obstacles.forEach(obs => {
        ctx.fillRect(obs.x, obs.y, obs.width, obs.height);
    });
}

// UPDATE
function update() {
    // PLAYER PHYSICS
    player.y += player.dy;
    player.dy += gravity;

    if (player.y >= 150) {
        player.y = 150;
        player.dy = 0;
        player.jumping = false;
    }

    // OBSTACLES
    if (Math.random() < 0.02) {
        obstacles.push({
            x: canvas.width,
            y: 150,
            width: 20,
            height: 20
        });
    }

    obstacles.forEach(obs => obs.x -= gameSpeed);

    // COLLISION
    for (let obs of obstacles) {
        if (
            player.x < obs.x + obs.width &&
            player.x + player.width > obs.x &&
            player.y < obs.y + obs.height &&
            player.y + player.height > obs.y
        ) {
            gameOver();
        }
    }

    // REMOVE OLD OBSTACLES
    obstacles = obstacles.filter(obs => obs.x > -20);

    // SCORE
    score++;
    document.getElementById("score").innerText = "Score: " + score;
}

// DRAW
function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // ground
    ctx.fillStyle = "#444";
    ctx.fillRect(0, 170, canvas.width, 5);

    drawPlayer();
    drawObstacles();
}

// GAME LOOP
function gameLoop() {
    if (!isGameRunning) return;

    update();
    draw();

    requestAnimationFrame(gameLoop);
}

// START
function startGame() {
    document.getElementById("startScreen").style.display = "none";
    canvas.style.display = "block";
    document.getElementById("score").style.display = "block";

    initGame();
    gameLoop();
}

// GAME OVER
function gameOver() {
    isGameRunning = false;

    canvas.style.display = "none";
    document.getElementById("score").style.display = "none";

    document.getElementById("gameOverScreen").style.display = "block";
    document.getElementById("finalScore").innerText = "Final Score: " + score;
}

// RESTART
function restartGame() {
    document.getElementById("gameOverScreen").style.display = "none";
    startGame();
}

// SINGLE INTERACTION: SPACEBAR
document.addEventListener("keydown", function(e) {
    if (e.code === "Space") {
        if (!player.jumping && isGameRunning) {
            player.dy = -10;
            player.jumping = true;
        }
    }
});
</script>

</body>
</html>
